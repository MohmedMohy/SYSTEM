generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Job {
  id        String   @id @default(cuid())
  title     String
  company   String?
  location  String?
  createdAt DateTime @default(now())
}

model Template {
  id          String   @id @default(cuid())
  name        String
  platform    String
  content     String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}